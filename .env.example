# ZACH website — environment variables for PRODUCTION
# Copy this file to ".env" on the server and fill in real values.
# Never commit the real ".env" file.

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=zach.org.zw,www.zach.org.zw
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ADMIN_URL=zachmain/

# Database (SQLite — leave as-is for shared hosting)
DATABASE_URL=sqlite:///db.sqlite3

# Email (update with real SMTP when available)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
